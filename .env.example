# Copy to .env and fill in. .env is gitignored.

# --- Lifelog daemon (Phase 1: capture + upload) ---
# Path to Firebase service-account JSON downloaded from Firebase console.
VIGNETTE_FIREBASE_CREDENTIALS=/home/hotaka/vignette/firebase-credentials.json
# Bucket name shown in Firebase Storage console (looks like "xxxx.appspot.com")
VIGNETTE_FIREBASE_BUCKET=
# GPIO BCM pin of the wired button (we confirmed GPIO5)
VIGNETTE_BUTTON_GPIO=5
# Seconds between captures while a session is active (default 30).
# NOTE: this env var is documentation-only; the real interval is set by
# scripts/pi_systemd/vignette-capture.timer (OnUnitInactiveSec). Keep them in sync.
VIGNETTE_CAPTURE_INTERVAL_SEC=30

# --- Phase 2: on-device Gemini analysis (not used in lifelog daemon yet) ---
GEMINI_API_KEY=
VIGNETTE_PHOTO_COUNT=5
VIGNETTE_PHOTO_INTERVAL_SEC=3
VIGNETTE_PHOTO_WIDTH=1920
VIGNETTE_PHOTO_HEIGHT=1080
VIGNETTE_GEMINI_MODEL=gemini-2.5-flash

# Other (unused by Vignette but kept for hardware tests)
OPENAI_API_KEY=
AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=
CAMERA_INDEX=0
BUTTON_GPIO=
