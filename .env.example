# Copy to .env and fill in. .env is gitignored.

# Required for analysis + prompt generation
GEMINI_API_KEY=

# Optional — tune capture behavior (defaults shown)
VIGNETTE_PHOTO_COUNT=5
VIGNETTE_PHOTO_INTERVAL_SEC=3
VIGNETTE_PHOTO_WIDTH=1920
VIGNETTE_PHOTO_HEIGHT=1080
VIGNETTE_GEMINI_MODEL=gemini-2.5-flash

# Other (unused by Vignette but kept for hardware tests)
OPENAI_API_KEY=
AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=
CAMERA_INDEX=0
BUTTON_GPIO=
