[Unit]
Description=Vignette button watcher — toggles capture sessions on GPIO5 press
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hotaka
WorkingDirectory=/home/hotaka/vignette
EnvironmentFile=-/home/hotaka/vignette/.env
ExecStart=/home/hotaka/vignette/venv/bin/python -m vignette.button_daemon
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
